<%- include('../../partials/header', { title, active: 'jobs' }) %>
<% if (notice) { %><div class="alert ok"><%= notice %></div><% } %>
<% if (error) { %><div class="alert error"><%= error %></div><% } %>
<div class="grid grid-2">
  <div class="card">
    <h3>Jobs</h3>
    <div class="table-wrap">
      <table>
        <thead><tr><th>ID</th><th>Type</th><th>Status</th><th>Progress</th><th>Created</th><th></th></tr></thead>
        <tbody>
          <% if (!jobs.length) { %><tr><td colspan="6" class="empty">No jobs yet.</td></tr><% } %>
          <% jobs.forEach(function(job){ %>
          <tr class="<%= job.status === 'running' || job.status === 'pending' ? 'row-active' : '' %>">
            <td><a href="/jobs/<%= job.id %>"><%= job.id %></a></td>
            <td><%= job.type %></td>
            <td><span class="badge <%= statusClass(job.status) %>"><%= job.status %></span></td>
            <td><%= job.progress %>%</td>
            <td><%= formatDate(job.created_at) %></td>
            <td>
              <% if (job.status !== 'running') { %>
              <form method="post" action="/jobs/<%= job.id %>/delete" onsubmit="return confirm('Delete this job?')">
                <button type="submit" class="btn secondary btn-sm">Delete</button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="card">
    <h3>Backup Runs</h3>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Account</th><th>Status</th><th>New</th><th>Started</th></tr></thead>
        <tbody>
          <% runs.forEach(function(run){ %>
          <tr>
            <td><%= run.account_label %></td>
            <td><span class="badge <%= statusClass(run.status) %>"><%= run.status %></span></td>
            <td><%= run.new_messages %></td>
            <td><%= formatDate(run.started_at) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>
