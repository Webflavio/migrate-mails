<%- include('../../partials/header', { title, active: 'accounts' }) %>
<% if (notice) { %><div class="alert ok"><%= notice %></div><% } %>
<% if (error) { %><div class="alert error"><%= error %></div><% } %>
<div class="grid grid-2">
  <div class="card">
    <h3><%= account.label %></h3>
    <p style="color:var(--cu-text-secondary)"><%= account.username %> · <%= account.imap_host %>:<%= account.imap_port %></p>
    <p>Status: <span class="badge <%= statusClass(account.status) %>"><%= account.status %></span></p>
    <p>Last backup: <%= formatDate(account.last_backup_at) %></p>
    <% var stats = backupStats || { messages: 0, bytes: 0, storageBytes: 0 }; %>
    <div class="backup-summary cols-2" style="margin-top:14px">
      <div class="stat-pill"><span>Backed up</span><strong><%= Number(stats.messages || 0).toLocaleString() %></strong></div>
      <div class="stat-pill"><span>Storage</span><strong><%= formatBytes(stats.storageBytes || stats.bytes || 0) %></strong></div>
    </div>
    <div class="btn-row btn-row-inline">
      <form method="post" action="/accounts/<%= account.id %>/test"><button class="btn secondary">Test Connection</button></form>
      <a class="btn" href="/accounts/<%= account.id %>/backup">Run Backup</a>
      <form method="post" action="/accounts/<%= account.id %>/index-legacy"><button class="btn secondary">Index Legacy Backup</button></form>
      <a class="btn secondary" href="/accounts/<%= account.id %>/edit">Edit</a>
      <a class="btn secondary" href="/browse/search?account=<%= account.id %>">Browse Emails</a>
    </div>
  </div>
  <div class="card">
    <h3>Backup History</h3>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Status</th><th>New</th><th>Errors</th><th>Started</th></tr></thead>
        <tbody>
          <% if (!runs.length) { %><tr><td colspan="4" class="empty">No runs yet.</td></tr><% } %>
          <% runs.forEach(function(run) { %>
          <tr>
            <td><span class="badge <%= statusClass(run.status) %>"><%= run.status %></span></td>
            <td><%= run.new_messages %></td>
            <td><%= run.error_count %></td>
            <td><%= formatDate(run.started_at) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<div class="card" style="margin-top:18px">
  <h3>Folders</h3>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Remote Name</th><th>Backed Up</th><th>Included</th><th>Last Synced</th><th>Actions</th></tr></thead>
      <tbody>
        <% if (!folders.length) { %><tr><td colspan="5" class="empty">No folders yet. Run a backup or index legacy data.</td></tr><% } %>
        <% folders.forEach(function(folder) { %>
        <tr>
          <td><%= folder.remote_name %></td>
          <td><%= folder.backed_up_count || 0 %></td>
          <td><%= folder.included ? 'Yes' : 'No' %></td>
          <td><%= formatDate(folder.last_synced_at) %></td>
          <td>
            <div class="actions-cell">
              <form method="post" action="/accounts/<%= account.id %>/folders/<%= folder.id %>/toggle">
                <input type="hidden" name="included" value="<%= folder.included ? '0' : '1' %>">
                <button type="submit" class="btn secondary btn-sm"><%= folder.included ? 'Exclude' : 'Include' %></button>
              </form>
              <% if (folder.backed_up_count > 0) { %>
              <form method="post" action="/accounts/<%= account.id %>/folders/<%= folder.id %>/clear" onsubmit="return confirm('Delete all backed-up messages in <%= folder.remote_name %>?')">
                <button type="submit" class="btn danger btn-sm">Clear</button>
              </form>
              <% } %>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<div class="card danger-zone" style="margin-top:18px">
  <h3>Danger Zone</h3>
  <div class="maintenance-grid">
    <form method="post" action="/accounts/<%= account.id %>/delete-backup" onsubmit="return confirm('Delete ALL backed-up emails for this account? The IMAP account settings will be kept.')">
      <p><strong>Delete backup data</strong></p>
      <p class="muted-sm">Removes <%= Number(stats.messages || 0).toLocaleString() %> message(s) and files. Account stays.</p>
      <button type="submit" class="btn danger" <%= stats.messages ? '' : 'disabled' %>>Delete Backup</button>
    </form>
    <form method="post" action="/accounts/<%= account.id %>/delete" onsubmit="return confirm('Delete this account and ALL its data permanently?')">
      <p><strong>Delete account</strong></p>
      <p class="muted-sm">Removes account, backups, and credentials.</p>
      <button class="btn danger">Delete Account</button>
    </form>
  </div>
</div>
<%- include('../../partials/footer') %>
